PORT=3002

# Supabase (service role key — bypasses RLS for read access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Gmail SMTP — email delivery via Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-account@gmail.com
SMTP_PASS=your-gmail-app-password
# Optional: override From address (defaults to SMTP_USER)
# EMAIL_FROM=reports@yourdomain.com

# ──────────────────────────────────────────────────────────────
# DO NOT SET REPORT_RECIPIENT_EMAIL or SUPER_ADMIN_EMAIL here.
# Those overrides bypass per-company recipient lookup and would
# send every company's report to a single hardcoded address.
# Recipients are always fetched from the database per company.
# ──────────────────────────────────────────────────────────────
