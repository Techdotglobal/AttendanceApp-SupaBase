PORT=3002

# Supabase (service role key — bypasses RLS for read access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend — email delivery (https://resend.com)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=reports@yourdomain.com

# ──────────────────────────────────────────────────────────────
# DO NOT SET REPORT_RECIPIENT_EMAIL or SUPER_ADMIN_EMAIL here.
# Those overrides bypass per-company recipient lookup and would
# send every company's report to a single hardcoded address.
# Recipients are always fetched from the database per company.
# ──────────────────────────────────────────────────────────────
